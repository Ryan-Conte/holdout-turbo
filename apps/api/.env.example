DATABASE_URL=postgresql://user:password@host/db?sslmode=require
JWT_SECRET=change-me-must-match-web
PORT=3001
CORS_ORIGIN=http://localhost:3000
PUBLIC_SERVER_URL=
SERVER_NAME=Local
SERVER_REGION=dev
SERVER_SORT=0
MAX_PLAYERS_PER_SERVER=200
# Optional for self-hosted worlds without a stable PUBLIC_SERVER_URL.
SERVER_STATE_KEY=
# "staging" loads latest drafts + latest draft map into an isolated world.
CONTENT_CHANNEL=live
# Staging servers stay out of the public browser unless explicitly enabled.
REGISTER_STAGING_SERVER=false
